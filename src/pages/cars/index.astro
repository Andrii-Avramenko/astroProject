---
import { getCollection } from "astro:content";
import CarItem from "../../components/CarItem.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const cars = await getCollection('cars')
---

<BaseLayout>
  <div class="content">
    <h2>Cars</h2>
    <ul class="carList">
      {
        cars.map(car => <CarItem car={car}/>)
      }
    </ul>
  </div>
</BaseLayout>

<style>
  .content {
    max-width: 1440px;
    margin: 0 auto;
    padding: 25px 0;
    text-align: center;
  }
</style>
